{
    "priority": 1,
    "request": {
        "method": "POST",
        "urlPath": "/v1/payments",
        "headers": {
            "X-Scenario": {
                "equalTo": "rate-limit"
            }
        }
    },
    "response": {
        "status": 429,
        "headers": {
            "Content-Type": "application/json",
            "Retry-After": "2"
        },
        "jsonBody": {
            "error": "rate_limited",
            "message": "Too many requests. Retry after 2 seconds."
        }
    }
}