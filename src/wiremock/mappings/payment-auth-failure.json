{
    "priority": 1,
    "request": {
        "method": "POST",
        "urlPath": "/v1/payments",
        "headers": {
            "Authorization": {
                "doesNotMatch": "Bearer valid-test-token"
            }
        }
    },
    "response": {
        "status": 401,
        "headers": {
            "Content-Type": "application/json"
        },
        "jsonBody": {
            "error": "unauthorized",
            "message": "Invalid or missing bearer token."
        }
    }
}